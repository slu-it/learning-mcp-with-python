# Copy to `.env` and adjust to match your Keycloak configuration.

# Public base URL of this server.
# Also the OAuth 2.0 resource identifier and the expected token `aud` claim,
# so it must match the audience your Keycloak audience mapper emits.
MCP_SERVER_URL=http://localhost:8000
# Scope a bearer token must carry to reach the /mcp endpoint.
MCP_REQUIRED_SCOPE=mcp:tools
# Scope a bearer token must carry to reach the REST API (/api/**).
API_REQUIRED_SCOPE=test-service-api

# Keycloak (OAuth 2.0 authorization server) location.
AUTH_HOST=localhost
AUTH_PORT=9000
AUTH_REALM=master
